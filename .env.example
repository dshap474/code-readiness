APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELEASE=local-dev
POSTGRES_DB=code_readiness
POSTGRES_USER=code_readiness
POSTGRES_PASSWORD=code_readiness
DATABASE_URL=postgresql+psycopg://code_readiness:code_readiness@127.0.0.1:5432/code_readiness
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_TIMEOUT_SECONDS=2.0
ANALYTICS_CIRCUIT_BREAKER_THRESHOLD=3
ANALYTICS_CIRCUIT_BREAKER_RESET_SECONDS=30
FEATURE_FLAGS=widget_write_enabled=true,widget_write_enabled_rollout=100
PRIVACY_CONTACT_EMAIL=privacy@example.invalid
PRIVACY_DATA_RETENTION_DAYS=30
PRIVACY_EXPORT_ENABLED=true
PRIVACY_DELETE_ENABLED=true
